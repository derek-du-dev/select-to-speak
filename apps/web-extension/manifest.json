{
  "manifest_version": 3,
  "name": "__MSG_ext_name__",
  "version": "1.0.3",
  "description": "__MSG_ext_desc__",
  "default_locale": "en",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "scripting"
  ],
  "icons": {
    "16": "assets/logo.png",
    "32": "assets/logo.png",
    "48": "assets/logo.png",
    "128": "assets/logo.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Select-to-Speak Manual",
    "default_icon": "assets/logo.png",
    "default_popup": "popup.html"
  },
  "commands": {
    "play-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "MacCtrl+Shift+Y"
      },
      "description": "__MSG_cmd_play_selection__"
    },
    "intensive-listening": {
      "suggested_key": {
        "default": "Ctrl+Shift+H",
        "mac": "MacCtrl+Shift+H"
      },
      "description": "__MSG_cmd_intensive_listening__"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "dist/tailwind.css",
        "assets/logo.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
