{
  "manifest_version": 3,
  "name": "Select-to-Speak English Assistant",
  "version": "1.0.1",
  "description": "Premium English learning assistant featuring text-to-speech selection playback and sentence-by-sentence intensive listening drawer.",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "scripting"
  ],
  "icons": {
    "16": "assets/logo.png",
    "32": "assets/logo.png",
    "48": "assets/logo.png",
    "128": "assets/logo.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Select-to-Speak Manual",
    "default_icon": "assets/logo.png",
    "default_popup": "popup.html"
  },
  "commands": {
    "play-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "MacCtrl+Shift+Y"
      },
      "description": "播放选中的文本 / Play selected text"
    },
    "intensive-listening": {
      "suggested_key": {
        "default": "Ctrl+Shift+H",
        "mac": "MacCtrl+Shift+H"
      },
      "description": "精听选中的文本 / Intensive listening on selected text"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["dist/tailwind.css", "assets/logo.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
